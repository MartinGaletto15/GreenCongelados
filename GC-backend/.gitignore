## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.
##
## Based on https://github.com/github/gitignore/blob/main/Dotnet.gitignore

#-------------------------------------------------
# .NET / Backend Rules
#-------------------------------------------------

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Project artifacts
artifacts/
publish/

# .NET Specific
project.lock.json
project.fragment.lock.json
ScaffoldingReadMe.txt
*.user
*.userosscache
*.sln.docstates

# User Secrets
appsettings.local.json
UserSecretsId

# NuGet Packages
*.nupkg
*.snupkg

# Others (incl. Visual Studio/MSBuild/etc.)
~$*
*~
CodeCoverage/
*.binlog
*.suo
*.user
*.sln.dotSettings.user
*.ide/
_ReSharper*/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

#-------------------------------------------------
# Agent / Project Specific
#-------------------------------------------------
.agents/
*.txt
GEMINI.md
*.db
*.db-shm
*.db-wal

#-------------------------------------------------
# Frontend (React, Vite, Node) Rules
#-------------------------------------------------

# Dependencias
node_modules/
**/.yarn/**

# Archivos de build y artefactos
dist/
.vite/

# Archivos de Log y caché
npm-debug.log*
yarn-error.log*
yarn-debug.log*
pnpm-debug.log*

# Variables de entorno
.env
.env.local
.env.*.local

#-------------------------------------------------
# IDE and OS Specific
#-------------------------------------------------
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
